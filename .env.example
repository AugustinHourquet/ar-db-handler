# ===========================================================================
# ar-db-handler — environment variables
# ===========================================================================
# Copy this file to .env and fill in real values. The .env file is gitignored.
#
# `sync_companies()` reads the GCS service-account JSON path from the
# environment. The variable name is OMAHA_GCS_CREDENTIALS so it matches the
# convention used by gcpBridge.py (the master pipeline).
#
# A caller may also pass `credentials_path=...` explicitly to sync_companies()
# — that argument wins over the env var.
# ===========================================================================

OMAHA_GCS_CREDENTIALS=/absolute/path/to/your/gcs_credentials.json
