# ===========================================================================
# ar-db-handler — environment variables
# ===========================================================================
# Copy this file to .env and fill in real values. The .env file is gitignored.

# Absolute path to gcpBridge.py in the global project (private, never committed).
# Required by sync_companies().
OMAHA_GCP_BRIDGE_PATH=/absolute/path/to/omaha_norma/src/omaha_norma/core/gcpBridge.py
OMAHA_NORMA_SRC_PATH=/absolute/path/to/omaha_norma/src

# GCS service-account credentials JSON. A caller may also pass
# `credentials_path=...` explicitly to sync_companies() — that wins over this.
OMAHA_GCS_CREDENTIALS=/absolute/path/to/your/gcs_credentials.json
